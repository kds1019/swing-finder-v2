# SwingFinder Secrets Configuration Template
# Copy this file to secrets.toml and fill in your actual values
# NEVER commit secrets.toml to GitHub!

# Required: Tiingo API (free tier available at tiingo.com)
TIINGO_API_KEY = "your_tiingo_api_key_here"
TIINGO_TOKEN = "your_tiingo_api_key_here"

# Optional: GitHub Gist (for cloud persistence)
# Get token: GitHub → Settings → Developer settings → Personal access tokens
# Scope needed: "gist"
GITHUB_GIST_TOKEN = "ghp_your_github_token_here"
GIST_ID = "your_gist_id_here"

# Optional: Email Alerts
# Use Gmail app password (not your regular password)
# Setup: Google Account → Security → 2-Step Verification → App passwords
ALERT_EMAIL = "your_gmail@gmail.com"
ALERT_EMAIL_PASSWORD = "your_app_password_here"
USER_EMAIL = "recipient@gmail.com"

# Optional: Alpaca Trading (paper trading)
ALPACA_KEY = "your_alpaca_key_here"
ALPACA_SECRET = "your_alpaca_secret_here"
ALPACA_BASE_URL = "https://paper-api.alpaca.markets"
ALPACA_DATA_URL = "https://data.alpaca.markets/v2"

# Optional: Yahoo Finance fallback
YAHOO_ENABLED = true

# Optional: Finnhub for news/sentiment
FINNHUB_KEY = "your_finnhub_key_here"

# Optional: Claude AI (for watchlist analysis)
# Get key: https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY = "sk-ant-your-key-here"

